# Copy this file to `.env` before starting the app.
# The runtime reads `.env` automatically and falls back to real shell env vars.

LLM_PROVIDER=openai_compatible
LLM_API_KEY=your_api_key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=120

# Optional dataset and artifact paths
# HOTPOT_DEV_PATH=artifacts/raw/hotpotqa/hotpot_dev_distractor_v1.json
# HOTPOT_TRAIN_PATH=artifacts/raw/hotpotqa/hotpot_train_v1.1.json
# DEFAULT_CHUNK_PATH=artifacts/chunks/dev_chunks.jsonl

# Retrieval defaults
DENSE_ENCODER_BACKEND=transformer
DENSE_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
DENSE_ENCODE_BATCH_SIZE=64
PRELOAD_RETRIEVERS=true
SEMANTIC_REFINER_ENABLED=false
